@model IEnumerable<AkademiqRapidApi.Models.Entities.AnalysisRecord>

@{
    ViewData["Title"] = "Analiz Sistemi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="font-headline text-2xl font-bold tracking-tight text-on-surface">
            Sistem Analiz Raporları
        </h1>
        <p class="text-xs text-outline font-['Space_Grotesk'] tracking-widest mt-1 uppercase">Nova Veri Çıkarımları</p>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    @foreach (var record in Model)
    {
        <div class="bento-item widget-card bg-surface-container border border-outline-variant/20 relative overflow-hidden rounded-xl p-6 group transition-transform hover:-translate-y-1 hover:border-cyan-400/30">
            <div class="absolute inset-0 glow-cyan-inner opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
            
            <div class="flex justify-between items-start mb-4 relative z-10">
                <div class="px-3 py-1 bg-primary-container border border-cyan-400/20 rounded font-headline text-[10px] text-cyan-400 tracking-wider">
                    @record.Type
                </div>
                <div class="font-[Space_Grotesk] text-[10px] text-outline">
                    @record.CreatedAt.ToString("dd MMM yyyy HH:mm")
                </div>
            </div>

            <div class="relative z-10 mb-4">
                <h3 class="font-headline text-lg font-bold text-on-surface mb-2">@record.Summary</h3>
                <p class="text-xs text-on-surface-variant leading-relaxed opacity-80">
                    @record.Details
                </p>
            </div>

            <div class="relative z-10 border-t border-outline-variant/10 pt-4 flex justify-between items-center group-hover:border-cyan-400/20 transition-colors">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-green-400" style="font-size:14px">check_circle</span>
                    <span class="text-[9px] text-outline font-headline uppercase tracking-widest">Durum Normal</span>
                </div>
                <button class="text-[9px] text-cyan-400 font-bold uppercase tracking-widest hover:text-cyan-300">İncele →</button>
            </div>
        </div>
    }
</div>
