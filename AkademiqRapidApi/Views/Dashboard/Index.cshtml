                            overflow-hidden shadow-2xl -rotate-2 group-hover:rotate-0 transition-transform duration-500 flex-shrink-0">
                    <img id="dash-movie-poster" src="https://placehold.co/300x450/111/444?text=Poster"
                         alt="" class="w-full h-full object-cover" />
                </div>
                <div class="text-right flex flex-col items-end">
                    <div class="text-amber-400 text-sm flex items-center gap-1">
                        <span class="material-symbols-outlined" style="font-size:14px">star</span>
                        <span id="dash-movie-rating">--/10</span>
                    </div>
                    <div class="font-headline text-xl font-black text-amber-400">TMDB</div>
                    <div class="text-[9px] text-outline">Günün Trendi</div>
                </div>
            </div>
            <div class="mt-auto">
                <div class="font-headline text-[9px] text-red-500 uppercase tracking-[2px] mb-1 flex items-center gap-1">
                    <span class="material-symbols-outlined" style="font-size:12px">local_movies</span> Sinema Kuşağı
                </div>
                <h3 id="dash-movie-title" class="font-headline text-xl font-bold mb-2 truncate">Yükleniyor...</h3>
                <p id="dash-movie-desc" class="text-[11px] text-outline leading-relaxed mb-3 line-clamp-3">
