@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="font-headline text-2xl font-bold tracking-tight text-on-surface">
            Sistem Kontrol Merkezi
        </h1>
    </div>
    <div class="flex items-center gap-3">
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-surface-container border border-outline-variant/20 text-[10px] font-headline uppercase tracking-wider">
            <span class="w-1.5 h-1.5 rounded-full bg-green-400 pulse-dot"></span>
            <span class="text-green-400">Sistemler Aktif</span>
        </div>
        <div class="font-['Space_Grotesk'] text-[11px] text-outline font-mono" id="page-clock">--:--:--</div>
    </div>
</div>


<div class="grid grid-cols-12 gap-5 auto-rows-[140px]">

    <div class="bento-item col-span-12 md:col-span-6 lg:col-span-4 row-span-2
                widget-card hud-tl hud-br
                bg-surface-container-low border border-outline-variant/10
                relative overflow-hidden rounded-lg">
        <div class="absolute inset-0 glow-cyan-inner pointer-events-none"></div>
        <div class="relative z-10 p-6 h-full flex flex-col justify-between">
            <span class="font-headline text-[9px] tracking-[2.5px] uppercase text-cyan-400/60">&#11044; CANLI SISTEM</span>
            <div>
                <div id="hero-clock"
                     class="font-headline text-5xl font-black tracking-tight text-primary-container
                            drop-shadow-[0_0_30px_rgba(0,242,255,.55)]">
                    00:00:00
                </div>
                <div id="hero-date" class="text-[11px] text-outline mt-1 tracking-wide"></div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div class="bg-surface-container border border-outline-variant/10 rounded p-3">
                    <div class="text-[9px] text-outline uppercase tracking-wider mb-1">Uptime</div>
                    <div id="uptime" class="font-headline text-sm font-bold text-on-surface font-mono">00:00:00</div>
                    <div class="text-[9px] text-green-400 mt-0.5">&#8593; Kesintisiz</div>
                </div>
                <div class="bg-surface-container border border-outline-variant/10 rounded p-3">
                    <div class="text-[9px] text-outline uppercase tracking-wider mb-1">Saat Dilimi</div>
                    <div class="font-headline text-sm font-bold text-on-surface font-mono">UTC+3</div>
                    <div class="text-[9px] text-outline mt-0.5">Istanbul/TR</div>
                </div>
            </div>
        </div>
    </div>

    <div id="dashboard-weather-widget"
         class="bento-item col-span-6 md:col-span-3 lg:col-span-2 row-span-2
                widget-card bg-surface-container-low border border-outline-variant/10
                relative overflow-hidden rounded-lg wx-loading">
        <div class="absolute inset-0 glow-cyan-inner pointer-events-none"></div>
        <div class="relative z-10 p-5 h-full flex flex-col justify-between">
            <div>
                <div class="font-headline text-[9px] uppercase tracking-[2px] text-outline mb-3 flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-cyan-400" style="font-size:13px">thermostat</span>
                    Hava Durumu
                </div>
                <div class="text-4xl mb-1" data-wx="icon">⏳</div>
                <div class="font-headline text-3xl font-black text-on-surface tracking-tight" data-wx="temp">
                    --
                </div>
            </div>
            <div>
                <p class="font-headline text-[9px] uppercase tracking-wider text-cyan-400 mb-2" data-wx="desc">Yükleniyor…</p>
                <p class="text-[9px] text-outline uppercase tracking-widest mb-2" data-wx="city">-- , --</p>
                <div class="space-y-1">
                    <div class="flex justify-between text-[9px]">
                        <span class="text-outline">Nem</span>
                        <span class="text-on-surface-variant font-medium" data-wx="humidity">--</span>
                    </div>
                    <div class="flex justify-between text-[9px]">
                        <span class="text-outline">Rüzgar</span>
                        <span class="text-on-surface-variant font-medium" data-wx="wind">--</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="bento-item col-span-12 lg:col-span-6 row-span-2
                widget-card bg-surface-container border border-outline-variant/10
                relative overflow-hidden rounded-lg flex flex-col">
        <div class="px-6 py-4 border-b border-outline-variant/10 flex items-center justify-between flex-shrink-0">
            <div class="font-headline text-[9px] uppercase tracking-[2.5px] text-outline flex items-center gap-1.5">
                <span class="material-symbols-outlined text-secondary-container" style="font-size:14px">currency_exchange</span>
                Guncel Doviz Kurlari
            </div>
            <span class="text-[9px] font-headline text-cyan-400/50 tracking-widest">CANLI_VERI</span>
        </div>
        <div class="flex-1 grid grid-cols-3 divide-x divide-outline-variant/10">
            <div class="p-5 flex flex-col justify-between hover:bg-surface-container-high/30 transition-colors">
                <span class="font-headline text-[9px] text-outline uppercase tracking-wider">USD / TRY</span>
                <div>
                    <div id="usd-val" class="font-headline text-xl font-bold text-on-surface transition-colors duration-500">38.42</div>
                    <div class="text-[9px] text-green-400 flex items-center gap-0.5 mt-1">
                        <span class="material-symbols-outlined" style="font-size:11px">trending_up</span>+0.21%
                    </div>
                </div>
            </div>
            <div class="p-5 flex flex-col justify-between hover:bg-surface-container-high/30 transition-colors">
                <span class="font-headline text-[9px] text-outline uppercase tracking-wider">EUR / TRY</span>
                <div>
                    <div id="eur-val" class="font-headline text-xl font-bold text-on-surface transition-colors duration-500">41.76</div>
                    <div class="text-[9px] text-error flex items-center gap-0.5 mt-1">
                        <span class="material-symbols-outlined" style="font-size:11px">trending_down</span>-0.12%
                    </div>
                </div>
            </div>
            <div class="p-5 flex flex-col justify-between hover:bg-surface-container-high/30 transition-colors">
                <span class="font-headline text-[9px] text-outline uppercase tracking-wider">GBP / TRY</span>
                <div>
                    <div id="gbp-val" class="font-headline text-xl font-bold text-on-surface transition-colors duration-500">49.11</div>
                    <div class="text-[9px] text-green-400 flex items-center gap-0.5 mt-1">
                        <span class="material-symbols-outlined" style="font-size:11px">trending_up</span>+0.05%
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="bento-item col-span-12 md:col-span-6 lg:col-span-3 row-span-3
                widget-card bg-surface-container-low border border-outline-variant/10
                relative overflow-hidden rounded-lg flex flex-col">
        <div class="absolute inset-0 glow-green-inner pointer-events-none"></div>
        <div class="relative z-10 px-5 pt-5 pb-2 border-b border-outline-variant/10 flex-shrink-0">
            <div class="font-headline text-[9px] uppercase tracking-[2.5px] text-outline flex items-center gap-1.5">
                <span class="material-symbols-outlined text-green-400" style="font-size:13px">currency_bitcoin</span>
                Kripto Piyasalari
            </div>
        </div>
        <div id="crypto-list" class="relative z-10 p-5 flex-1 flex flex-col gap-3 overflow-hidden">
            <div class="flex items-center justify-between p-3 rounded bg-surface-container border border-outline-variant/10 hover:border-green-400/20 transition-colors">
                <div class="crypto-icon bg-yellow-500/10 border border-yellow-500/25 text-yellow-400">BTC</div>
                <div class="flex-1 px-3">
                    <div class="font-headline text-xs font-bold">Bitcoin</div>
                    <div class="text-[9px] text-outline">BTC</div>
                </div>
                <div class="text-right">
                    <div class="font-headline text-sm font-bold text-green-400">$84,231</div>
                    <div class="text-[9px] text-green-400">+2.4%</div>
                </div>
            </div>
            <div class="flex items-center justify-between p-3 rounded bg-surface-container border border-outline-variant/10 hover:border-green-400/20 transition-colors">
                <div class="crypto-icon bg-indigo-500/10 border border-indigo-500/25 text-indigo-400">ETH</div>
                <div class="flex-1 px-3">
                    <div class="font-headline text-xs font-bold">Ethereum</div>
                    <div class="text-[9px] text-outline">ETH</div>
                </div>
                <div class="text-right">
                    <div class="font-headline text-sm font-bold text-green-400">$2,186</div>
                    <div class="text-[9px] text-green-400">+1.8%</div>
                </div>
            </div>
            <div class="flex items-center justify-between p-3 rounded bg-surface-container border border-outline-variant/10 hover:border-green-400/20 transition-colors">
                <div class="crypto-icon bg-purple-500/10 border border-purple-500/25 text-purple-400">SOL</div>
                <div class="flex-1 px-3">
                    <div class="font-headline text-xs font-bold">Solana</div>
                    <div class="text-[9px] text-outline">SOL</div>
                </div>
                <div class="text-right">
                    <div class="font-headline text-sm font-bold text-green-400">$132.45</div>
                    <div class="text-[9px] text-green-400">+5.2%</div>
                </div>
            </div>
            <div class="flex items-center justify-between p-3 rounded bg-surface-container border border-outline-variant/10 hover:border-red-400/20 transition-colors">
                <div class="crypto-icon bg-red-500/10 border border-red-500/25 text-red-400">XRP</div>
                <div class="flex-1 px-3">
                    <div class="font-headline text-xs font-bold">XRP</div>
                    <div class="text-[9px] text-outline">XRP</div>
                </div>
                <div class="text-right">
                    <div class="font-headline text-sm font-bold text-error">$2.04</div>
                    <div class="text-[9px] text-error">-0.9%</div>
                </div>
            </div>
            <div class="mt-auto">
                <div class="h-[3px] bg-outline-variant/20 rounded-full overflow-hidden">
                    <div class="h-full w-[72%] progress-fill rounded-full"></div>
                </div>
                <div class="flex justify-between mt-2">
                    <span class="text-[9px] text-outline uppercase tracking-wider">Toplam Hacim</span>
                    <span class="text-[9px] text-green-400 font-bold">$2.4T</span>
                </div>
            </div>
        </div>
    </div>

    <div class="bento-item col-span-12 md:col-span-6 lg:col-span-3 row-span-2
                widget-card hud-tl hud-br
                bg-surface-container-high border border-outline-variant/10
                relative overflow-hidden rounded-lg">
        <div class="p-5 h-full flex flex-col">
            <div class="font-headline text-[9px] uppercase tracking-[2.5px] text-outline flex items-center gap-1.5 mb-4">
                <span class="material-symbols-outlined text-cyan-400" style="font-size:13px">local_gas_station</span>
                Akaryakit Fiyatlari
            </div>
            <div id="gas-wrapper" class="flex-1 flex flex-col gap-2.5">
                <div class="flex justify-between items-center p-2.5 rounded bg-surface-container border border-outline-variant/10 hover:border-cyan-500/20 transition-colors">
                    <span class="text-[11px] text-on-surface-variant">Motorin</span>
                    <div class="flex items-center gap-2">
                        <span class="font-headline text-sm font-bold text-primary-container">44.85 TL</span>
                        <span class="text-[8px] font-bold text-green-400 bg-green-400/10 border border-green-400/20 px-1.5 py-0.5 rounded-full">+0.12%</span>
                    </div>
                </div>
                <div class="flex justify-between items-center p-2.5 rounded bg-surface-container border border-outline-variant/10 hover:border-cyan-500/20 transition-colors">
                    <span class="text-[11px] text-on-surface-variant">Benzin</span>
                    <div class="flex items-center gap-2">
                        <span class="font-headline text-sm font-bold text-primary-container">43.42 TL</span>
                        <span class="text-[8px] font-bold text-error bg-error/10 border border-error/20 px-1.5 py-0.5 rounded-full">-0.05%</span>
                    </div>
                </div>
                <div class="flex justify-between items-center p-2.5 rounded bg-surface-container border border-outline-variant/10 hover:border-cyan-500/20 transition-colors">
                    <span class="text-[11px] text-on-surface-variant">LPG</span>
                    <div class="flex items-center gap-2">
                        <span class="font-headline text-sm font-bold text-primary-container">23.19 TL</span>
                        <span class="text-[8px] font-bold text-green-400 bg-green-400/10 border border-green-400/20 px-1.5 py-0.5 rounded-full">+0.44%</span>
                    </div>
                </div>
            </div>
            <svg class="w-full mt-3" height="36" viewBox="0 0 200 36" fill="none">
                <path d="M0,28 Q25,8 50,18 T100,12 T150,22 T200,14"
                      stroke="#00dbe7" stroke-width="1.5" fill="none" opacity=".5" />
                <path d="M0,28 Q25,8 50,18 T100,12 T150,22 T200,14 L200,36 L0,36 Z"
                      fill="url(#fuelGrad)" opacity=".15" />
                <defs>
                    <linearGradient id="fuelGrad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#00dbe7" />
                        <stop offset="100%" stop-color="transparent" />
                    </linearGradient>
                </defs>
            </svg>
        </div>
    </div>

    <div class="bento-item col-span-12 lg:col-span-6 row-span-2
                widget-card bg-surface-container-low border border-outline-variant/10
                relative overflow-hidden rounded-lg"
         id="fb-dashboard-widget">
        <div class="absolute inset-0 glow-pink-inner pointer-events-none"></div>
        <div class="relative z-10 p-5 h-full flex flex-col">
            <div class="flex items-center justify-between mb-2">
                <div class="font-headline text-[9px] uppercase tracking-[2.5px] text-outline flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-secondary-container" style="font-size:13px">sports_soccer</span>
                    <span data-fb="league">Futbol &middot; Güncel Maç</span>
                </div>
                <div data-fb="badge" class="flex items-center gap-1.5 px-2 py-1 rounded-full bg-outline-variant/10 border border-outline-variant/20">
                    <span class="font-headline text-[8px] text-outline uppercase tracking-wider">Yükleniyor…</span>
                </div>
            </div>
            <div class="flex-1 flex items-center justify-around px-4">
                <div class="flex flex-col items-center gap-2 text-center w-28">
                    <img data-fb="homeLogo" src="" alt=""
                         class="w-12 h-12 object-contain rounded-xl bg-surface-container border border-outline-variant/20 p-1"
                         style="display:none" onerror="this.style.display='none'" />
                    <div class="w-12 h-12 rounded-xl bg-outline-variant/10 border border-outline-variant/20
                                flex items-center justify-center font-['Space_Grotesk'] text-xs font-black text-outline fb-logo-fallback"
                         data-fb="homePlaceholder">—</div>
                    <span class="font-headline text-[9px] uppercase text-outline tracking-wider" data-fb="homeName">Ev Sahibi</span>
                </div>
                <div class="text-center">
                    <div class="font-headline text-5xl font-black text-on-surface
                                drop-shadow-[0_0_12px_rgba(255,255,255,.15)] flex items-center gap-3">
                        <span data-fb="scoreHome">—</span>
                        <span class="text-xl text-outline-variant">:</span>
                        <span data-fb="scoreAway">—</span>
                    </div>
                    <a href="/Football" class="font-headline text-[9px] text-outline uppercase tracking-wider mt-2 block
                                              hover:text-primary-container transition-colors">
                        Tüm Maçlar →
                    </a>
                </div>
                <div class="flex flex-col items-center gap-2 text-center w-28">
                    <img data-fb="awayLogo" src="" alt=""
                         class="w-12 h-12 object-contain rounded-xl bg-surface-container border border-outline-variant/20 p-1"
                         style="display:none" onerror="this.style.display='none'" />
                    <div class="w-12 h-12 rounded-xl bg-outline-variant/10 border border-outline-variant/20
                                flex items-center justify-center font-['Space_Grotesk'] text-xs font-black text-outline"
                         data-fb="awayPlaceholder">—</div>
                    <span class="font-headline text-[9px] uppercase text-outline tracking-wider" data-fb="awayName">Deplasman</span>
                </div>
            </div>
        </div>
    </div>

    <div class="bento-item col-span-12 md:col-span-8 lg:col-span-5 row-span-3
                widget-card border border-outline-variant/10
                relative overflow-hidden rounded-lg group cursor-pointer">
        <div class="absolute inset-0">
            <img id="dash-recipe-img" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDiWM53Q_TbaOI-1cCRp8MrZKD9pBdqQVVu4YJgRHWRIZKiJxC8spYSy56J5zSRqxnsVgamMNosYPv6lYUt_-54593ENA3bYKIu-qOhxExymajKZ2NvJmv9qwoQdefcZSVVRxLts5Oejyxo-ogxI-vBQcWuFgH-G5I5n4CbR5oIlhlooJImzo0jBNXae_MSQ8H1hoc32MktYBt_ZYhwJswxeaKty-2a49ti0ISum8_C1ALR94yeoMBFda1y-oPcTpUr7MmTn9o4DqZm"
