                </span>
                <span class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-secondary-container" style="font-size:11px">people</span><span id="dash-recipe-portion">-- kisi</span>
                </span>
                <span class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-secondary-container" style="font-size:11px">whatshot</span><span id="dash-recipe-diff">--</span>
                </span>
