        </div>
        <div class="relative z-10 h-full p-7 flex flex-col justify-end">
            <div class="flex items-center gap-1.5 mb-2">
                <span class="material-symbols-outlined text-secondary-container" style="font-size:12px">restaurant</span>
                <span class="font-headline text-[9px] text-secondary-container uppercase tracking-[2px]">Gunun Yemek Onerisi</span>
            </div>
            <h3 id="dash-recipe-title" class="font-headline text-2xl font-bold mb-1 tracking-tight">Yükleniyor...</h3>
