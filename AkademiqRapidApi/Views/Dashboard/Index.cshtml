    <div class="bento-item col-span-12 md:col-span-6 lg:col-span-4 row-span-4
                widget-card bg-surface-container-high border border-outline-variant/10
                relative overflow-hidden rounded-lg flex flex-col">
        <div class="px-5 py-4 border-b border-outline-variant/10 flex items-center justify-between flex-shrink-0">
            <div class="font-headline text-[9px] uppercase tracking-[2.5px] text-outline flex items-center gap-1.5">
                <span class="material-symbols-outlined text-cyan-400" style="font-size:13px">newspaper</span>
                Guncel Haberler
