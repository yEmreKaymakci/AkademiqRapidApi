<header class="fixed top-0 right-0 w-[calc(100%-16rem)] z-50 flex justify-between items-center px-8 h-16 bg-slate-900/30 backdrop-blur-md border-b border-fuchsia-500/10 shadow-[0_0_20px_0px_rgba(0,242,255,0.05)]">
    <div class="flex items-center gap-8">
        <span class="font-black text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-fuchsia-500 font-headline text-lg tracking-tighter">DASHBOARD</span>
        <div class="hidden lg:flex items-center bg-surface-container-high/50 border border-outline-variant/20 px-3 py-1.5 rounded-lg">
            <span class="material-symbols-outlined text-outline text-sm mr-2">search</span>
            <input id="globalSearchInput" class="bg-transparent border-none focus:ring-0 text-xs font-body w-48 text-on-surface placeholder-outline/50 outline-none" placeholder="Sistemde ara..." type="text" autocomplete="off" />
        </div>
    </div>
    
    @{
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    }

    <nav class="flex items-center gap-6">
        <a class="@(currentController == "Dashboard" ? "text-cyan-400 border-cyan-400" : "text-slate-400 border-transparent hover:text-cyan-400") border-b-[2px] transition-all font-['Space_Grotesk'] text-sm font-bold py-5 tracking-wide" href="/Dashboard/Index">Sistem</a>
        <a class="@(currentController == "Analysis" ? "text-cyan-400 border-cyan-400" : "text-slate-400 border-transparent hover:text-cyan-400") border-b-[2px] transition-all font-['Space_Grotesk'] text-sm font-bold py-5 tracking-wide" href="/Analysis/Index">Analiz</a>
        <a class="@(currentController == "Archive" ? "text-cyan-400 border-cyan-400" : "text-slate-400 border-transparent hover:text-cyan-400") border-b-[2px] transition-all font-['Space_Grotesk'] text-sm font-bold py-5 tracking-wide" href="/Archive/Index">Arşiv</a>
    </nav>
    <div class="flex items-center gap-4">
        <!-- İkonlar kaldırıldı -->
    </div>
</header>