 <aside class="fixed left-0 top-0 h-full z-40 flex flex-col py-6 bg-slate-950/40 backdrop-blur-xl w-64 border-r border-cyan-500/15 shadow-[0_0_20px_0px_rgba(0,242,255,0.15)]">
    <div class="px-6 mb-10">
        <h1 class="text-xl font-bold tracking-tighter text-cyan-400 drop-shadow-[0_0_8px_rgba(0,242,255,0.8)] font-headline uppercase">STRYK_OS</h1>
        <p class="font-['Space_Grotesk'] tracking-wider uppercase text-[10px] text-cyan-400/60 mt-1">SYSTEM_ACTIVE</p>
    </div>
    <nav class="flex-1 px-3 space-y-1">
        @{
            var ctrl = ViewContext.RouteData.Values["Controller"]?.ToString();
            var menuItems = new[] {
                ("Dashboard", "space_dashboard", "Dashboard"),
                ("ChatBot", "smart_toy", "Nova"),
                ("Gas", "local_gas_station", "Akaryakıt"),
                ("ConvertCurrency", "payments", "Döviz"),
                ("Coin", "currency_bitcoin", "Kripto"),
                ("Recipe", "restaurant", "Yemek"),
                ("Weather", "cloudy_snowing", "Hava"),
                ("Football", "sports_soccer", "Futbol"),
                ("News", "newspaper", "Haberler"),
                ("Movie", "movie", "Filmler"),
                ("Music", "music_note", "Müzik"),
                ("Motivation", "format_quote", "Motivasyon")
            };

            foreach (var item in menuItems)
            {
                var isActive = ctrl == item.Item1;
                var aClass = isActive 
                    ? "text-cyan-400 bg-cyan-500/10 border-r-2 border-cyan-400 shadow-[inset_-10px_0_15px_-10px_rgba(0,242,255,0.3)]" 
                    : "text-slate-500 hover:text-cyan-200 transition-colors border-r-2 border-transparent";

                <a class="flex items-center px-4 py-3 @aClass group transition-all" href="/@item.Item1/Index">
                    <span class="material-symbols-outlined mr-3">@item.Item2</span>
                    <span class="font-['Space_Grotesk'] tracking-wider uppercase text-[10px]">@item.Item3</span>
                </a>
            }
        }
    </nav>
    <div class="mt-auto px-6 flex items-center gap-3 border-t border-cyan-500/10 pt-6">
        <div class="w-10 h-10 rounded-full overflow-hidden border border-cyan-400/30">
            <img alt="User Profile HUD" class="w-full h-full object-cover" data-alt="Futuristic cybernetic user profile avatar portrait" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDDrrII00VhZ12tLODmURQqfX0Y_ceSkpvSW0BQUaNR9RQ9YJh_tWxHRy16XPw7oRckh7CwHbAG16s4-2vee_eL7A8JnuDC1fI6j6AijkS0fD1tp_-ydPIUDu2QV_Ih2LVIUrJG1lJsmE8S1RmR95xhIjoLH_r-BHL2Z0b88OWh8C8yft3B3WHdNV7mWPAzC2S4cj5TC6QrEYR9aOrCj_DpQDW8Dtavw3rgojkrwpSb5q83gI6yitgU37beMfmhr4y-1pe5_IuVbui4" />
        </div>
        <div class="flex flex-col">
            <span class="font-headline text-[10px] text-cyan-400 font-bold">OPERATOR_01</span>
            <span class="font-headline text-[8px] text-fuchsia-400">LEVEL_MAX</span>
        </div>
    </div>
</aside>