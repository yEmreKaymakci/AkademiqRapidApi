@model AkademiqRapidApi.Models.CoinViewModel.Rootobject
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<link rel="stylesheet" href="~/css/coin.css" />

<div class="coin-terminal p-4">
    <div class="container">
        <div class="row align-items-center mb-5 bento-item">
            <div class="col-md-8">
                <h2 class="display-6 fw-bold" style="color: #22c55e; text-shadow: 0 0 15px rgba(34,197,94,0.3);">
                    <i class="fa-solid fa-chart-area me-2"></i> Kripto Varlık Terminali
                </h2>
                <p class="text-secondary mb-0">Küresel piyasa verileri ve anlık varlık değişimleri</p>
            </div>
            <div class="col-md-4 text-end">
                <a href="/Dashboard/Index" class="btn btn-outline-success px-4">Panele Dön</a>
            </div>
        </div>

        <div class="row g-4 mb-5" id="featuredCoinsArea">
        </div>

        <div class="row bento-item">
            <div class="col-12">
                <div class="card bg-dark text-white border-secondary widget-card position-relative hud-tl hud-br glow-green-inner rounded-3">
                    <div class="card-body">
                        <h5 class="card-title mb-4" style="color: #22c55e;">Piyasa Listesi</h5>
                        <div class="table-responsive">
                            <table class="table table-dark table-hover align-middle mb-0">
                                <thead>
                                    <tr style="border-bottom: 2px solid rgba(34,197,94,0.2);">
                                        <th>Sıra</th>
                                        <th>Varlık</th>
                                        <th>Fiyat (USD)</th>
                                        <th>Piyasa Değeri</th>
                                        <th>Değişim (24s)</th>
                                    </tr>
                                </thead>
                                <tbody id="coinTableBody"></tbody>
                            </table>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top border-secondary">
                            <span id="coinTotalInfo" class="text-secondary small opacity-75"></span>
                            <div class="d-flex align-items-center gap-3">
                                <button id="coinPrevBtn" class="btn-coin-nav"><i class="fa-solid fa-arrow-left"></i></button>
                                <div class="page-indicator-box">
                                    <span id="coinPageIndicator" class="fw-bold">1 / 1</span>
                                </div>
                                <button id="coinNextBtn" class="btn-coin-nav"><i class="fa-solid fa-arrow-right"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="application/json" id="coinDataJson">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model))</script>
    <script src="~/js/coin.js" asp-append-version="true"></script>
}