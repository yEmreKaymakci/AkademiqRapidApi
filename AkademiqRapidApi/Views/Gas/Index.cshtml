@model List<AkademiqRapidApi.Models.GasViewModel.Result>

<link rel="stylesheet" href="~/css/gas.css" />
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<div class="gas-terminal p-4">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-md-8">
                <h1 class="display-6 fw-bold text-info">Akaryakıt Veri Terminali</h1>
                <p class="text-secondary">Avrupa genelindeki anlık yakıt fiyat endeksi ve analizleri</p>
            </div>
            <div class="col-md-4 text-end">
                <a href="/Dashboard/Index" class="btn btn-nav">Panele Dön</a>
            </div>
        </div>

        <div class="row g-4 mb-5">
            @{
                var tr = Model.FirstOrDefault(x => x.country.Contains("Turkey") || x.country.Contains("Türkiye"));
            }
            <div class="col-md-4">
                <div class="stat-card shadow-sm">
                    <small class="text-secondary">🇹🇷 Türkiye - Benzin</small>
                    <div class="stat-value text-info">@(tr?.gasoline ?? "---")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card shadow-sm">
                    <small class="text-secondary">🇹🇷 Türkiye - Motorin</small>
                    <div class="stat-value text-warning">@(tr?.diesel ?? "---")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card shadow-sm">
                    <small class="text-secondary">Bölgesel Ortalama (Tahmini)</small>
                    <div class="stat-value text-secondary">€ 1.48</div>
                </div>
            </div>
        </div>

        <div class="row g-5">
            <div class="col-lg-7">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Canlı Fiyat Listesi</h5>
                    <div class="d-flex align-items-center gap-3">
                        <span id="pageInfo" class="small text-secondary"></span>
                        <button id="btnPrev" class="btn-nav">← Önceki</button>
                        <button id="btnNext" class="btn-nav">Sonraki →</button>
                    </div>
                </div>
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Ülke</th>
                            <th>Benzin</th>
                            <th>Motorin</th>
                            <th>LPG</th>
                            <th>Birim</th>
                        </tr>
                    </thead>
                    <tbody id="gasTableBody"></tbody>
                </table>
            </div>
            <div class="col-lg-5">
                <h5 class="mb-4">Fiyat Dağılım Grafiği (İlk 12 Ülke)</h5>
                <div class="stat-card" id="gasChart"></div>
            </div>
        </div>
    </div>
</div>

<script type="application/json" id="gasDataJson">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model))</script>
<script src="~/js/gas.js"></script>